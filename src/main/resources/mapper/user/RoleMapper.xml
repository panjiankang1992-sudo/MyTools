<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.yuyutian.mytools.user.mapper.RoleMapper">

    <resultMap id="RoleResultMap" type="com.yuyutian.mytools.user.Model.Role">
        <id column="id" property="id"/>
        <result column="role_name" property="roleName"/>
        <result column="description" property="description"/>
        <result column="create_time" property="createTime"/>
    </resultMap>

    <select id="findByRoleName" resultMap="RoleResultMap">
        SELECT id, role_name, description, create_time FROM t_role WHERE role_name = #{roleName}
    </select>

    <select id="findDefaultUserRole" resultMap="RoleResultMap">
        SELECT id, role_name, description, create_time FROM t_role WHERE role_name = 'USER'
    </select>

</mapper>