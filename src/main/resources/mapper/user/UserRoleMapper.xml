<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.yuyutian.mytools.user.mapper.UserRoleMapper">

    <resultMap id="UserRoleResultMap" type="com.yuyutian.mytools.user.Model.UserRole">
        <id column="id" property="id"/>
        <result column="user_id" property="userId"/>
        <result column="role_id" property="roleId"/>
        <result column="create_time" property="createTime"/>
    </resultMap>

    <insert id="insert" parameterType="com.yuyutian.mytools.user.Model.UserRole">
        INSERT INTO t_user_role (id, user_id, role_id, create_time)
        VALUES (#{id}, #{userId}, #{roleId}, #{createTime})
    </insert>

    <select id="findByUserId" resultMap="UserRoleResultMap">
        SELECT id, user_id, role_id, create_time FROM t_user_role WHERE user_id = #{userId}
    </select>

    <delete id="deleteByUserId">
        DELETE FROM t_user_role WHERE user_id = #{userId}
    </delete>

</mapper>